# ==============================================
# Smart Laundry Management System - Server Config
# PostgreSQL Version
# ==============================================

# Server Configuration
# ====================
PORT=5000
NODE_ENV=development

# Database Configuration (PostgreSQL)
# ====================================
# Railway/Heroku/Render will provide DATABASE_URL automatically
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/laundry_db

# For local development, you can use individual variables:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your_password
# PGDATABASE=laundry_db

# Security
# ========
JWT_SECRET=laundry_smart_secret_key_2024_change_this_in_production

# Frontend URL for CORS (production)
# ===================================
FRONTEND_URL=https://your-app.vercel.app

# ==============================================
# Instructions for Local Development
# ==============================================
#
# 1. Install PostgreSQL:
#    - Windows: https://www.postgresql.org/download/windows/
#    - Mac: brew install postgresql
#    - Linux: sudo apt-get install postgresql
#
# 2. Create database:
#    psql -U postgres
#    CREATE DATABASE laundry_db;
#    \q
#
# 3. Copy this file to .env and update values
#    cp .env.example .env
#
# 4. Install dependencies:
#    npm install
#
# 5. Run the server:
#    npm start
#
# The server will automatically:
#    - Connect to PostgreSQL
#    - Run migrations to create tables
#    - Seed default data (admin, cashier, worker accounts)
#
# ==============================================
# Instructions for Railway Deployment
# ==============================================
#
# 1. Create PostgreSQL database in Railway:
#    - Click "+ New" → "Database" → "PostgreSQL"
#    - Railway will auto-generate DATABASE_URL
#
# 2. Set environment variables in Railway:
#    - JWT_SECRET=your_secret_key_here
#    - FRONTEND_URL=https://your-vercel-app.vercel.app
#    - NODE_ENV=production
#
# 3. Deploy:
#    - Connect your GitHub repo
#    - Railway will auto-deploy on push
#
# DATABASE_URL is automatically provided by Railway!
#
# ==============================================
# Default User Accounts (after seed)
# ==============================================
#
# Admin Account:
#    Email: admin@laundry.com
#    Password: admin123
#    Role: admin (full access)
#
# Cashier Account:
#    Email: cashier@laundry.com
#    Password: cashier123
#    Role: cashier (orders, payments, customers)
#
# Worker Account:
#    Email: worker@laundry.com
#    Password: worker123
#    Role: worker (item status management)
#
# ==============================================
